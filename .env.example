ANTHROPIC_API_KEY=sk-ant-...
# LOG_LEVEL=INFO                  # DEBUG shows vapi speech-update / conversation-update webhooks
# LOGFIRE_TOKEN=pylf_v1_...       # optional; when set, traces go to Logfire only (no console tree)
# LOGFIRE_PROJECT=voice-agent     # used to build trace URLs
# DATABASE_URL=sqlite:///voice_agent.db

# Vapi (required for live calls, optional for local play.py simulation)
# VAPI_API_KEY=...
# VAPI_PHONE_NUMBER_ID=...        # Vapi phone number to dial out from
# WEBHOOK_URL=https://your-ngrok-url  # public base URL (ngrok or deployed); /vapi/webhook is appended


# VAPI_VOICE_PROVIDER=vapi
# VAPI_VOICE_ID=Elliot
# Optional ElevenLabs-only tuning (ignored when VAPI_VOICE_PROVIDER=vapi):
# VAPI_VOICE_SPEED=0.95              # slightly slower can feel more natural (typ. ~0.8–1.1)
# VAPI_VOICE_STABILITY=0.45          # lower → more expressive; higher → steadier/robotic
# VAPI_VOICE_SIMILARITY_BOOST=0.75   # typ. ~0.5–0.9
# VAPI_VOICE_STYLE=0.0               # style exaggeration; 0 is neutral if your voice supports it
