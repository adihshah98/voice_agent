ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...             # optional; when set, interviewer tries gpt-4.1-mini before Haiku
# OPENAI_MODEL=openai:gpt-4.1-mini  # override or set OPENAI_MODEL="" to skip OpenAI despite key
# OPENAI_PROMPT_CACHE_KEY=voice_agent_interviewer  # empty = omit prompt_cache_key (disables explicit OpenAI prefix grouping)
# OPENAI_PROMPT_CACHE_RETENTION=24h                  # in_memory | 24h — extended prefix retention on OpenAI's side
# INTERVIEWER_PROMPT_CACHE_VERSION=1                 # bump when system prompt or user-prefix layout changes (OpenAI key suffix)
GOOGLE_API_KEY=AIza...              # Gemini tier in interviewer fallback chain
CEREBRAS_API_KEY=csk-...            # optional; omit key or set CEREBRAS_MODEL="" to drop Cerebras from interviewer chain
# CEREBRAS_MODEL=cerebras:llama3.1-8b   # optional override (same provider:model pattern as HAIKU_MODEL / GEMINI_MODEL)
# LOG_LEVEL=INFO                  # DEBUG shows vapi speech-update / conversation-update webhooks
# LOGFIRE_TOKEN=pylf_v1_...       # optional; when set, traces go to Logfire only (no console tree)
# LOGFIRE_PROJECT=voice-agent     # used to build trace URLs
# DATABASE_URL=sqlite:///voice_agent.db

# Vapi (required for live calls, optional for local play.py simulation)
# VAPI_API_KEY=...
# VAPI_PHONE_NUMBER_ID=...        # Vapi phone number to dial out from
# VAPI_WEBHOOK_SECRET=...              # HMAC secret key from Vapi credential; empty = skip check (dev)
# VAPI_SERVER_CREDENTIAL_ID=cred_...  # HMAC credential ID → attached to server (webhook) URL on dial
# VAPI_SIGNATURE_HEADER=x-signature   # must match "Signature Header" in Vapi HMAC credential (default: x-signature)
# VAPI_TIMESTAMP_HEADER=x-timestamp   # must match "Timestamp Header" in credential; empty = no timestamp in payload
# WEBHOOK_URL=https://your-ngrok-url  # public base URL (ngrok or deployed); /vapi/webhook is appended
# LLM_SECRET_TOKEN=...                # static secret Vapi sends in X-Vapi-Secret on every LLM request; empty = skip check (dev)


# VAPI_VOICE_PROVIDER=11labs          # "11labs" (default) or "vapi" (built-in Elliot voice)
# VAPI_VOICE_ID=<your-11labs-voice-id>
# VAPI_VOICE_MODEL=eleven_flash_v2_5  # ElevenLabs model — Flash v2.5 = ~75ms latency, natural quality
                                      # (omit to use ElevenLabs default; "eleven_multilingual_v2" = max quality)
# Optional ElevenLabs-only tuning (ignored when VAPI_VOICE_PROVIDER=vapi):
# VAPI_VOICE_CHUNK_MIN_CHARACTERS=1  # streaming TTS flush threshold; default 1 = first audio on short fillers (was 10)
# VAPI_VOICE_STABILITY=0.45          # lower → more expressive; higher → steadier/robotic (default: 0.5)
# VAPI_VOICE_SIMILARITY_BOOST=0.75   # typ. ~0.5–0.9
# VAPI_VOICE_STYLE=0.10              # slight style exaggeration for warmth; 0 = neutral
# VAPI_VOICE_SPEED=0.95              # slightly slower can feel more natural (typ. ~0.8–1.1)

# Voice pipeline — endpointing & interruption (all optional, values shown are the defaults)
# VAPI_WAIT_SECONDS=0.3              # delay before assistant speaks after turn ends
# VAPI_STOP_NUM_WORDS=3              # words user must say before assistant stops (blocks backchannel interrupts)
# VAPI_STOP_BACKOFF_SECONDS=1.0      # wait after real interruption before speaking again
# VAPI_EXTENDED_SILENCE_SECONDS=0    # after assistant finishes speaking, end call if user is silent this long; 0 = off (try 30–45)

# Interviewer: spoken line when the model reply cannot be parsed into utterance + metadata (empty, JSON-only, etc.)
# INTERVIEWER_RECOVERY_UTTERANCE=Hey, sorry I could not hear you — could you come again?
